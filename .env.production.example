# VPS production env

NODE_ENV=production
APP_BASE_URL=https://your-domain.com
NEXT_PUBLIC_APP_BASE_URL=https://your-domain.com
LOG_LEVEL=info
BETTER_AUTH_SECRET=replace-with-a-long-random-secret-at-least-32-chars
DATABASE_URL=postgres://efiles_app:replace-with-your-db-password@127.0.0.1:5432/efiles_prod
ADMIN_INGEST_TOKEN=replace-with-a-long-random-secret
CHAT_BYPASS_SECRET=replace-with-a-long-random-secret-for-private-chat-access

# Not used if you only index from laptop
PDF_DATA_DIR=/dev/null
HOSTNAME=127.0.0.1
PORT=3000

# Hosted chat model on the VPS
# Nebius works here because it exposes an OpenAI-compatible API.
LLM_PROVIDER=openai-compatible
LLM_API_KEY=replace-with-your-nebius-api-key
LLM_BASE_URL=https://api.tokenfactory.nebius.com/v1
LLM_MODEL=replace-with-your-nebius-chat-model
LLM_TIMEOUT_MS=30000
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TEMPERATURE=0.1

# Keep these even if the VPS is not generating embeddings itself.
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_API_KEY=ollama
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIMENSIONS=128

RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
RAG_TOP_K_VECTOR=20
RAG_TOP_K_LEXICAL=20
RAG_TOP_K_FINAL=8
RAG_MAX_CONTEXT_CHARS=24000

RATE_LIMIT_CHAT_WINDOW_SEC=60
RATE_LIMIT_CHAT_MAX=10
RATE_LIMIT_THREADS_WINDOW_SEC=60
RATE_LIMIT_THREADS_MAX=20
RATE_LIMIT_INDEX_WINDOW_SEC=60
RATE_LIMIT_INDEX_MAX=3

X402_ENABLED=false
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
X402_AMOUNT=10000
X402_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e
X402_PAY_TO=
X402_MAX_TIMEOUT_SECONDS=60
X402_RESOURCE_DESCRIPTION=Per-request chat response
X402_RESOURCE_MIME_TYPE=application/json
X402_ASSET_NAME=USDC
X402_ASSET_VERSION=2

JOB_WORKER_POLL_MS=1000
JOB_WORKER_CONCURRENCY=1
JOB_MAX_ATTEMPTS=5
JOB_RETRY_BASE_MS=5000
JOB_RETRY_MAX_MS=60000
